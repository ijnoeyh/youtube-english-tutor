# ── 필수 ──────────────────────────────────────────────────────────────────
# Groq API 키 — Whisper(STT) + Llama(LLM) 호출용. Speak/Write/Agent에 필수.
# https://console.groq.com/keys 에서 무료 발급
GROQ_API_KEY=

# ── 선택 (없어도 동작) ─────────────────────────────────────────────────────
# YouTube Data API v3 키 — 영상 제목/썸네일 메타데이터용. 없으면 자동 폴백.
# (자막은 youtube-transcript-api라 키 없이도 추출됨)
YOUTUBE_API_KEY=

# CORS 허용 origin(콤마 구분). 수동 실행 시 프론트 주소. Docker(단일출처)에선 불필요.
CORS_ALLOW_ORIGINS=http://localhost:3000

# SQLite 경로. 기본은 backend/app.db. docker compose는 자체 볼륨 경로로 덮어씀.
DATABASE_URL=sqlite:///./app.db

# Groq 호출 1건당 최대 대기(초) — 외부 API 무응답 시 무한 대기 방지
GROQ_TIMEOUT=30

# Groq rate limit(429) 시 SDK 자동 재시도 횟수
GROQ_MAX_RETRIES=3

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
